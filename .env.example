# TradePilot MCP Server Configuration
# Copy this file to .env and fill in your actual values

# Polygon.io API Key (Required)
# Get your free key at: https://polygon.io/
POLYGON_API_KEY=your_polygon_api_key_here

# Server Configuration (Optional)
PORT=10000

# Python Version (for deployment)
PYTHON_VERSION=3.11

# TastyTrade Sandbox (Optional — for paper-trading execution)
# Create a sandbox account at: https://developer.tastytrade.com/sandbox/
TASTYTRADE_USERNAME=your_sandbox_username
TASTYTRADE_PASSWORD=your_sandbox_password
TASTYTRADE_SANDBOX=true
